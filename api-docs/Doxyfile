# Blusys API reference — Doxygen config (spike: hal/gpio.h only)

PROJECT_NAME           = "Blusys API Reference"
PROJECT_BRIEF          = "Embedded Application Platform"
PROJECT_NUMBER         =
OUTPUT_DIRECTORY       = api-docs/build

# ---------------------------------------------------------------------------
# Scope — spike only indexes the single annotated header.
# ---------------------------------------------------------------------------
INPUT                  = components/blusys/include/blusys/hal/adc.h \
                         components/blusys/include/blusys/hal/dac.h \
                         components/blusys/include/blusys/hal/efuse.h \
                         components/blusys/include/blusys/hal/gpio.h \
                         components/blusys/include/blusys/hal/i2c.h \
                         components/blusys/include/blusys/hal/i2c_slave.h \
                         components/blusys/include/blusys/hal/i2s.h \
                         components/blusys/include/blusys/hal/mcpwm.h \
                         components/blusys/include/blusys/hal/nvs.h \
                         components/blusys/include/blusys/hal/one_wire.h \
                         components/blusys/include/blusys/hal/pcnt.h \
                         components/blusys/include/blusys/hal/pwm.h \
                         components/blusys/include/blusys/hal/rmt.h \
                         components/blusys/include/blusys/hal/sdm.h \
                         components/blusys/include/blusys/hal/sleep.h \
                         components/blusys/include/blusys/hal/spi.h \
                         components/blusys/include/blusys/hal/spi_slave.h \
                         components/blusys/include/blusys/hal/system.h \
                         components/blusys/include/blusys/hal/target.h \
                         components/blusys/include/blusys/hal/temp_sensor.h \
                         components/blusys/include/blusys/hal/timer.h \
                         components/blusys/include/blusys/hal/touch.h \
                         components/blusys/include/blusys/hal/twai.h \
                         components/blusys/include/blusys/hal/uart.h \
                         components/blusys/include/blusys/hal/version.h \
                         components/blusys/include/blusys/hal/wdt.h
RECURSIVE              = NO
FILE_PATTERNS          = *.h *.hpp
EXTRACT_ALL            = NO
EXTRACT_STATIC         = NO
EXTRACT_PRIVATE        = NO
EXTRACT_PRIV_VIRTUAL   = NO
OPTIMIZE_OUTPUT_FOR_C  = YES
JAVADOC_AUTOBRIEF      = YES
MARKDOWN_SUPPORT       = YES
AUTOLINK_SUPPORT       = YES
HIDE_UNDOC_MEMBERS     = NO
WARN_IF_UNDOCUMENTED   = YES
WARN_IF_DOC_ERROR      = YES
WARN_IF_INCOMPLETE_DOC = YES
WARN_AS_ERROR          = FAIL_ON_WARNINGS
QUIET                  = YES

# ---------------------------------------------------------------------------
# Output formats — HTML only for the public site.
# ---------------------------------------------------------------------------
GENERATE_HTML          = YES
GENERATE_LATEX         = NO
GENERATE_XML           = NO
GENERATE_TREEVIEW      = YES
DISABLE_INDEX          = NO
FULL_SIDEBAR           = NO
HTML_COLORSTYLE        = LIGHT

# ---------------------------------------------------------------------------
# doxygen-awesome-css theme.
# ---------------------------------------------------------------------------
HTML_EXTRA_STYLESHEET  = api-docs/awesome/doxygen-awesome.css \
                         api-docs/awesome/doxygen-awesome-sidebar-only.css

# ---------------------------------------------------------------------------
# Diagrams — off for the spike; revisit if desired.
# ---------------------------------------------------------------------------
HAVE_DOT               = NO
