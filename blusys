blusys_create_app_main_headless() {
    local target_dir="$1"
    cat > "$target_dir/main/app_main.cpp" <<'CPP'
// app_main.cpp — headless product entry point.
//
// Brings up the framework runtime, registers a single home_controller, and
// drives the runtime tick from the main task. Headless products still go
// through blusys_framework/core; only blusys_framework/ui is excluded.

#include "blusys/framework/framework.hpp"
#include "blusys/log.h"
#include "controllers/home_controller.hpp"

#include "freertos/FreeRTOS.h"
#include "freertos/task.h"
#include "esp_timer.h"

namespace {
constexpr const char *kTag = "app_main";
}

extern "C" void app_main(void)
{
    blusys::framework::init();

    static home_controller controller;
    static blusys::framework::runtime runtime;

    const blusys_err_t err = runtime.init(&controller, /*output_route_sink=*/nullptr, 10);
    if (err != BLUSYS_OK) {
        BLUSYS_LOGE(kTag, "runtime.init failed: %d", static_cast<int>(err));
        return;
    }

    BLUSYS_LOGI(kTag, "headless product running");

    // Main loop: tick the runtime, drive integrations from here. A real
    // headless product would post integration events from MQTT/sensor tasks.
    while (true) {
        runtime.step(static_cast<std::uint32_t>(esp_timer_get_time() / 1000));
        vTaskDelay(pdMS_TO_TICKS(10));
    }
}
CPP
}

