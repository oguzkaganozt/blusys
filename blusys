void main_screen_create(blusys::framework::runtime *runtime)
{
    lv_obj_t *screen = blusys::ui::screen_create({});

    lv_obj_t *col = blusys::ui::col_create(screen, {
        .gap     = blusys::ui::theme().spacing_md,
        .padding = blusys::ui::theme().spacing_lg,
    });

    blusys::ui::label_create(col, {
        .text = "Hello, blusys",
        .font = blusys::ui::theme().font_title,
    });
    blusys::ui::divider_create(col, {});

    lv_obj_t *row = blusys::ui::row_create(col, {
        .gap     = blusys::ui::theme().spacing_sm,
        .padding = 0,
    });

    blusys::ui::button_create(row, {
        .label    = "-",
        .variant  = blusys::ui::button_variant::secondary,
        .on_press = +[](void *user_data) {
            auto *rt = static_cast<blusys::framework::runtime *>(user_data);
            rt->post_intent(blusys::framework::intent::decrement);
        },
        .user_data = runtime,
    });
    blusys::ui::button_create(row, {
        .label    = "+",
        .variant  = blusys::ui::button_variant::primary,
        .on_press = +[](void *user_data) {
            auto *rt = static_cast<blusys::framework::runtime *>(user_data);
            rt->post_intent(blusys::framework::intent::increment);
        },
        .user_data = runtime,
    });

    lv_group_t *group = blusys::ui::create_encoder_group();
    blusys::ui::auto_focus_screen(screen, group);

    // Activate the freshly-built screen. Without this call the display
    // keeps showing whatever default screen LVGL created, not our widgets.
    lv_screen_load(screen);
}

