# ── Subcommands ──────────────────────────────────────────────────────────────

cmd_create() {
    local starter="interactive"
    local positional=()

    while [[ $# -gt 0 ]]; do
        case "$1" in
            --starter)
                if [[ $# -lt 2 ]]; then
                    printf 'error: --starter requires an argument (headless|interactive)\n' >&2
                    exit 1
                fi
                starter="$2"
                shift 2
                ;;
            --starter=*)
                starter="${1#--starter=}"
                shift
                ;;
            -h|--help)
                blusys_help_create
                exit 0
                ;;
            --*)
                printf 'error: unknown option %s\n' "$1" >&2
                blusys_help_create
                exit 1
                ;;
            *)
                positional+=("$1")
                shift
                ;;
        esac
    done

    if [[ ${#positional[@]} -gt 1 ]]; then
        blusys_help_create
        exit 1
    fi

    case "$starter" in
        headless|interactive) ;;
        *)
            printf 'error: --starter must be "headless" or "interactive" (got %q)\n' "$starter" >&2
            exit 1
            ;;
    esac

    local target_dir
    if [[ ${#positional[@]} -eq 0 ]]; then
        target_dir="$(pwd)"
    else
        if [[ "${positional[0]}" = /* ]]; then
            target_dir="${positional[0]}"
        else
            target_dir="$(pwd)/${positional[0]}"
        fi
    fi

    mkdir -p "$target_dir"
    target_dir="$(cd "$target_dir" && pwd)"

    local project_name
    project_name="$(basename "$target_dir")"

    # Check for existing project files. The Phase 7 scaffold ships four
    # CMakeLists files (top-level + main/ + app/ + app/product_config.cmake)
    # plus app_main.cpp and idf_component.yml.
    local existing_files=()
    for f in \
        CMakeLists.txt \
        sdkconfig.defaults \
        main/CMakeLists.txt \
        main/app_main.cpp \
        main/idf_component.yml \
        app/CMakeLists.txt \
        app/product_config.cmake \
        app/controllers/home_controller.hpp \
        app/controllers/home_controller.cpp; do
        [[ -f "$target_dir/$f" ]] && existing_files+=("$f")
    done

    if [[ ${#existing_files[@]} -gt 0 ]]; then
        printf 'The following files already exist in %s:\n' "$target_dir"
        for f in "${existing_files[@]}"; do
            printf '  %s\n' "$f"
        done
        printf 'Overwrite? [y/N] '
        read -r answer
        if [[ "$answer" != [yY] ]]; then
            printf 'Aborted.\n'
            exit 0
        fi
    fi

    mkdir -p \
        "$target_dir/main" \
        "$target_dir/app/controllers" \
        "$target_dir/app/integrations" \
        "$target_dir/app/config"

    if [[ "$starter" == "interactive" ]]; then
        mkdir -p \
            "$target_dir/app/ui/screens" \
            "$target_dir/app/ui/widgets"
    fi

    blusys_create_top_cmakelists "$target_dir"
    blusys_create_main "$target_dir" "$starter"
    blusys_create_app "$target_dir" "$project_name" "$starter"
    blusys_create_sample_controller "$target_dir"
    if [[ "$starter" == "interactive" ]]; then
        blusys_create_sample_ui "$target_dir"
    fi

    # Empty marker files so empty directories survive git add.
    touch \
        "$target_dir/app/integrations/.keep" \
        "$target_dir/app/config/.keep"
    if [[ "$starter" == "interactive" ]]; then
        touch "$target_dir/app/ui/widgets/.keep"
    fi

    if [[ "$starter" == "interactive" ]]; then
        # The interactive starter compiles blusys_framework/ui, which drives
        # LVGL from the blusys_ui render task. Without LV_OS_FREERTOS the
        # LVGL global lock is a no-op and render/main race into an
        # LV_ASSERT_MSG "Invalidate area is not allowed during rendering"
        # whose default handler is `while(1);` — i.e. a hang. LV_COLOR_DEPTH_16
        # matches the RGB565 color format blusys_ui uses with the LCD driver.
        cat > "$target_dir/sdkconfig.defaults" <<'DEFAULTS'
CONFIG_LV_OS_FREERTOS=y
CONFIG_LV_COLOR_DEPTH_16=y
DEFAULTS
    else
        touch "$target_dir/sdkconfig.defaults"
    fi

    printf '\nCreated blusys project: %s\n' "$target_dir"
    printf 'Starter type: %s\n\n' "$starter"
    printf 'Next steps:\n'
    printf '  cd %s\n' "$target_dir"
    printf '  blusys build                # build for default target\n'
    printf '  blusys run                  # build, flash, and monitor\n'
    printf '  blusys config               # open menuconfig\n'
    printf '\n'
