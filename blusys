//      runtime.step, which may mutate widgets via the controller) MUST
//      run under blusys_ui_lock / blusys_ui_unlock. See the main loop
//      below.
//   4. CONFIG_LV_OS_FREERTOS must be set in sdkconfig.defaults — the
//      scaffold writes it for you, do not remove it.

#include "blusys/blusys.h"
#include "blusys/blusys_services.h"
#include "blusys/framework/framework.hpp"
#include "blusys/framework/ui/widgets.hpp"
#include "blusys/log.h"
#include "controllers/home_controller.hpp"
#include "ui/theme_init.hpp"
#include "ui/screens/main_screen.hpp"

#include "freertos/FreeRTOS.h"
#include "freertos/task.h"
#include "esp_timer.h"

namespace {
constexpr const char *kTag = "app_main";
}

extern "C" void app_main(void)
{
    blusys::framework::init();

