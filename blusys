    local target_dir="$1"
    cat > "$target_dir/app/controllers/home_controller.hpp" <<'HPP'
#pragma once

#include "blusys/framework/core/controller.hpp"

class home_controller final : public blusys::framework::controller {
public:
    blusys_err_t init() override;
    void handle(const blusys::framework::app_event &event) override;
    void tick(std::uint32_t now_ms) override;

    int counter() const { return counter_; }

private:
    int counter_ = 0;
};
HPP

    cat > "$target_dir/app/controllers/home_controller.cpp" <<'CPP'
#include "controllers/home_controller.hpp"

#include "blusys/log.h"

namespace {
constexpr const char *kTag = "home_controller";
}

blusys_err_t home_controller::init()
{
    counter_ = 0;
    BLUSYS_LOGI(kTag, "home_controller initialized");
    return BLUSYS_OK;
}

void home_controller::handle(const blusys::framework::app_event &event)
{
    if (event.kind != blusys::framework::app_event_kind::intent) {
        return;
    }

    switch (blusys::framework::app_event_intent(event)) {
    case blusys::framework::intent::increment:
        ++counter_;
        BLUSYS_LOGI(kTag, "counter=%d", counter_);
        emit_feedback({
            .channel = blusys::framework::feedback_channel::haptic,
            .pattern = blusys::framework::feedback_pattern::click,
            .value   = 1,
            .payload = nullptr,
        });
        break;
    case blusys::framework::intent::decrement:
        --counter_;
        BLUSYS_LOGI(kTag, "counter=%d", counter_);
        emit_feedback({
            .channel = blusys::framework::feedback_channel::haptic,
            .pattern = blusys::framework::feedback_pattern::click,
            .value   = 1,
            .payload = nullptr,
        });
        break;
    case blusys::framework::intent::confirm:
        BLUSYS_LOGI(kTag, "confirm at counter=%d", counter_);
        emit_feedback({
            .channel = blusys::framework::feedback_channel::audio,
            .pattern = blusys::framework::feedback_pattern::confirm,
            .value   = 1,
            .payload = nullptr,
        });
        break;
    default:
        break;
    }
}

void home_controller::tick(std::uint32_t /*now_ms*/)
{
    // Periodic work goes here. Called once per runtime tick.
}
CPP
}

