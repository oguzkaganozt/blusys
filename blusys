#!/usr/bin/env bash

set -euo pipefail

# ── Constants ────────────────────────────────────────────────────────────────

BLUSYS_REPO_ROOT="$(cd "$(dirname "$(readlink -f "$0")")" && pwd)"
BLUSYS_DEFAULT_TARGET="esp32s3"
BLUSYS_DEFAULT_PROJECT="."
BLUSYS_MIN_IDF_MAJOR=5
BLUSYS_MIN_IDF_MINOR=5
BLUSYS_SCAFFOLD_PLATFORM_VERSION="${BLUSYS_SCAFFOLD_PLATFORM_VERSION:-$(git -C "$BLUSYS_REPO_ROOT" symbolic-ref --quiet --short HEAD 2>/dev/null || printf 'main')}"

BLUSYS_CONFIG_DIR="${XDG_CONFIG_HOME:-$HOME/.config}/blusys"
BLUSYS_CONFIG_FILE="$BLUSYS_CONFIG_DIR/config"

export BLUSYS_PATH="$BLUSYS_REPO_ROOT"

# Load saved config (IDF_PATH etc.) — env vars take precedence
if [[ -f "$BLUSYS_CONFIG_FILE" ]]; then
    while IFS='=' read -r key value; do
        [[ -z "$key" || "$key" = \#* ]] && continue
        key="$(printf '%s' "$key" | tr -d '[:space:]')"
        value="$(printf '%s' "$value" | sed 's/^[[:space:]]*//')"
        case "$key" in
            IDF_PATH)
                if [[ -z "${IDF_PATH:-}" ]]; then
                    export IDF_PATH="$value"
                fi
                ;;
            QEMU_PATH)
                if [[ -z "${QEMU_PATH:-}" ]]; then
                    export QEMU_PATH="$value"
                fi
                ;;
        esac
    done < "$BLUSYS_CONFIG_FILE"
fi

# shellcheck source=scripts/lib/blusys/common.sh
. "${BLUSYS_REPO_ROOT}/scripts/lib/blusys/common.sh"
# shellcheck source=scripts/lib/blusys/help.sh
. "${BLUSYS_REPO_ROOT}/scripts/lib/blusys/help.sh"
# shellcheck source=scripts/lib/blusys/create.sh
. "${BLUSYS_REPO_ROOT}/scripts/lib/blusys/create.sh"
# shellcheck source=scripts/lib/blusys/commands.sh
. "${BLUSYS_REPO_ROOT}/scripts/lib/blusys/commands.sh"

main "$@"
