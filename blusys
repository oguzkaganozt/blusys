    //                  .cs_pin = 7, .dc_pin = 3,
    //                  .rst_pin = -1, .bl_pin = -1,
    //                  .pclk_hz = 8000000,
    //                  .x_offset = 0, .y_offset = 0 },
    //     };
    //     if (blusys_lcd_open(&lcd_config, &lcd) != BLUSYS_OK) { return; }
    //
    //     blusys_ui_t            *ui = nullptr;
    //     const blusys_ui_config_t ui_config = {
    //         .lcd = lcd, .buf_lines = 20,
    //         .full_refresh = false,
    //         .task_priority = 0, .task_stack = 0,
    //     };
    //     if (blusys_ui_open(&ui_config, &ui) != BLUSYS_OK) {
    //         blusys_lcd_close(lcd);
    //         return;
    //     }
    //
    // Product teams: replace the stub below with the real init, keep the
    // resulting `blusys_ui_t *ui` in scope for the main loop.
    blusys_ui_t *ui = nullptr;
    BLUSYS_LOGW(kTag,
                "interactive starter: LCD not opened — fill in the TODO "
                "block in app_main.cpp before this board will draw anything");
    // ──────────────────────────────────────────────────────────────────

    static home_controller           controller;
    static blusys::framework::runtime runtime;

    const blusys_err_t init_err = runtime.init(
        &controller, /*output_route_sink=*/nullptr, /*queue_depth=*/10);
    if (init_err != BLUSYS_OK) {
        BLUSYS_LOGE(kTag, "runtime.init failed: %d", static_cast<int>(init_err));
        return;
    }

    // Build the widget-kit screen under the UI lock so the blusys_ui
    // render task never sees a half-constructed screen. If the TODO
    // block above is still a stub, `ui` is nullptr and we skip the
    // widget kit entirely — the framework spine still runs so sensor
    // integrations and headless flows keep working.
    if (ui != nullptr) {
        blusys_ui_lock(ui);
        app::ui::theme_init();
        app::ui::main_screen_create(&runtime);
