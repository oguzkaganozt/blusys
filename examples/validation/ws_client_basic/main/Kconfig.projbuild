menu "WebSocket Client Basic Example"

    config WIFI_SSID
        string "WiFi SSID"
        default "myssid"
        help
            SSID (network name) of the access point to connect to.

    config WIFI_PASSWORD
        string "WiFi Password"
        default "mypassword"
        help
            WiFi password. Leave empty for open networks.

    config WIFI_CONNECT_TIMEOUT_MS
        int "WiFi connect timeout (ms)"
        default 10000
        range 1000 60000
        help
            Maximum time in milliseconds to wait for an IP address.

    config WS_SERVER_URL
        string "WebSocket server URL"
        default "ws://echo.websocket.events"
        help
            Full WebSocket URL including scheme and path.
            Use ws:// for plain WebSocket or wss:// for TLS.

    config WS_CONNECT_TIMEOUT_MS
        int "WebSocket connect timeout (ms)"
        default 10000
        range 1000 60000
        help
            Maximum time in milliseconds to wait for the WebSocket handshake.

    config WS_SEND_INTERVAL_MS
        int "Message send interval (ms)"
        default 5000
        range 500 60000
        help
            How often to send a test message to the server.

endmenu
