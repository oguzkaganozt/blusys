menu "OTA Basic Example"

    config WIFI_SSID
        string "WiFi SSID"
        default "myssid"
        help
            SSID of the AP to connect to.

    config WIFI_PASSWORD
        string "WiFi Password"
        default "mypassword"
        help
            Password of the AP. Leave empty for open networks.

    config WIFI_CONNECT_TIMEOUT_MS
        int "WiFi connect timeout (ms)"
        default 10000
        range 1000 60000
        help
            Maximum time to wait for a WiFi connection in milliseconds.

    config OTA_FIRMWARE_URL
        string "Firmware URL"
        default "http://192.168.1.100:8080/firmware.bin"
        help
            URL of the firmware binary to download. Supports HTTP and HTTPS.
            For HTTPS, set OTA_CERT_PEM or the server must use a trusted CA.

endmenu
