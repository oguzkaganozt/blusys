menu "Blusys ADC Basic Example"

config BLUSYS_ADC_BASIC_PIN
    int "ADC GPIO pin"
    range 0 48
    default 4 if IDF_TARGET_ESP32C3
    default 4 if IDF_TARGET_ESP32S3
    help
        Select a board-safe ADC1 GPIO for this example.

config BLUSYS_ADC_BASIC_ATTEN_DB_12
    bool "Use 12 dB attenuation"
    default y
    help
        Disable this only if you specifically want 0 dB mode for lower input voltages.

endmenu
