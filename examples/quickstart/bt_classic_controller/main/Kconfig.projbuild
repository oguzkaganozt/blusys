menu "BT Classic Controller example"

    config BTCC_DEVICE_NAME
        string "Classic BT advertised device name"
        default "Oxa BT Controller"
        help
            Shown in the OS Bluetooth pairing UI.

    config BTCC_ENCODER_CLK_GPIO
        int "Encoder CLK (A) GPIO"
        default 32
        help
            CLK/A pin of the EC11 rotary encoder. CW rotation emits Volume Up.
            Must be an RTC-capable GPIO (0,2,4,12-15,25-27,32-39) to serve as
            an ext1 deep-sleep wakeup source.

    config BTCC_ENCODER_DT_GPIO
        int "Encoder DT (B) GPIO"
        default 33
        help
            DT/B pin of the EC11 rotary encoder. CCW rotation emits Volume Down.

    config BTCC_ENCODER_SW_GPIO
        int "Encoder switch (button) GPIO"
        default 23
        help
            Push-button pin of the EC11. Short press = context action (mute /
            play-pause). -1 to disable.
            NOTE: GPIO23 is NOT an RTC GPIO on the original ESP32; it cannot
            be used as an ext1 deep-sleep wakeup source. Only CLK (GPIO32)
            is used for wakeup.

    config BTCC_ENCODER_LONG_PRESS_MS
        int "Encoder button long-press threshold (ms)"
        default 600
        help
            Hold time that triggers a long press, which cycles the operating
            mode (volume → media → brightness → volume). Short press still
            performs the context action (mute / play-pause).

    config BTCC_STATUS_LED_GPIO
        int "Status LED GPIO (-1 to disable)"
        default -1
        help
            Drives a status LED. Off while idle, blinks while discoverable,
            solid while a client is connected. -1 disables.

    config BTCC_STATUS_LED_ACTIVE_LOW
        bool "Status LED is active-low"
        default n

    config BTCC_BATTERY_ADC_GPIO
        int "Battery voltage ADC GPIO (-1 to disable)"
        default -1
        help
            GPIO connected to a resistor divider across the battery. Sampled
            every 30 s. -1 disables battery reporting.

    config BTCC_BATTERY_MV_EMPTY
        int "ADC pin voltage at 0% battery (mV)"
        default 1500
        help
            Expected ADC pin millivolts when battery is fully discharged.
            For a LiPo (3.0 V min) through a 1:1 divider this is 1500 mV.

    config BTCC_BATTERY_MV_FULL
        int "ADC pin voltage at 100% battery (mV)"
        default 2100
        help
            Expected ADC pin millivolts when battery is fully charged.
            For a LiPo (4.2 V max) through a 1:1 divider this is 2100 mV.

    config BTCC_SLEEP_TIMEOUT_S
        int "Deep-sleep inactivity timeout in seconds (0 = disabled)"
        default 120
        help
            Seconds of encoder inactivity before the device enters deep sleep.
            Wakeup source: ext1 on GPIO32 (CLK) — a low edge on that pin
            (encoder rotation) wakes the device. GPIO23 (SW button) is NOT an
            RTC GPIO on ESP32 and cannot be used for ext1 wakeup. Set 0 to
            disable deep sleep entirely.

    config BTCC_DISPLAY_ENABLED
        bool "Enable SSD1306 128x64 OLED display"
        default y
        help
            Show BLE status, active mode, volume level, and AVRCP track info
            on a 128x64 SSD1306 connected via I2C.

    config BTCC_DISPLAY_I2C_SDA_GPIO
        int "Display I2C SDA GPIO"
        default 21
        depends on BTCC_DISPLAY_ENABLED

    config BTCC_DISPLAY_I2C_SCL_GPIO
        int "Display I2C SCL GPIO"
        default 22
        depends on BTCC_DISPLAY_ENABLED

endmenu
