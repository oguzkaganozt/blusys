menu "Headless example"

    config WIFI_SSID
        string "WiFi SSID"
        default "myssid"
        help
            SSID of the AP to connect to.

    config WIFI_PASSWORD
        string "WiFi Password"
        default "mypassword"
        help
            Password of the AP. Leave empty for open networks.

    config BLUSYS_HEADLESS_TELEMETRY_LOCAL_UI
        bool "Local SSD1306 status OLED (128x64 I2C)"
        default n
        help
            When enabled, uses BLUSYS_APP_MAIN_DEVICE with a minimal mono status
            screen (same core/ and capabilities as headless). Host and headless
            simulator builds stay unchanged.

endmenu
