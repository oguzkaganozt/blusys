menu "7-Segment Display Example"

    choice EXAMPLE_DRIVER
        prompt "Driver type"
        default EXAMPLE_DRIVER_MAX7219
        help
            Select the 7-segment display driver to use.

        config EXAMPLE_DRIVER_GPIO
            bool "Direct GPIO"
        config EXAMPLE_DRIVER_74HC595
            bool "74HC595 shift register"
        config EXAMPLE_DRIVER_MAX7219
            bool "MAX7219 SPI controller"
    endchoice

    if EXAMPLE_DRIVER_GPIO
        config EXAMPLE_GPIO_PIN_A
            int "Segment A pin"
            default 2
        config EXAMPLE_GPIO_PIN_B
            int "Segment B pin"
            default 4
        config EXAMPLE_GPIO_PIN_C
            int "Segment C pin"
            default 5
        config EXAMPLE_GPIO_PIN_D
            int "Segment D pin"
            default 18
        config EXAMPLE_GPIO_PIN_E
            int "Segment E pin"
            default 19
        config EXAMPLE_GPIO_PIN_F
            int "Segment F pin"
            default 21
        config EXAMPLE_GPIO_PIN_G
            int "Segment G pin"
            default 22
        config EXAMPLE_GPIO_PIN_DP
            int "Decimal point pin (-1 to disable)"
            default -1
        config EXAMPLE_GPIO_COMMON0
            int "Common pin digit 0"
            default 23
        config EXAMPLE_GPIO_COMMON1
            int "Common pin digit 1 (-1 to disable)"
            default -1
        config EXAMPLE_GPIO_COMMON2
            int "Common pin digit 2 (-1 to disable)"
            default -1
        config EXAMPLE_GPIO_COMMON3
            int "Common pin digit 3 (-1 to disable)"
            default -1
        config EXAMPLE_GPIO_DIGIT_COUNT
            int "Number of digits (1-8)"
            default 1
            range 1 8
        config EXAMPLE_GPIO_COMMON_ANODE
            bool "Common anode (uncheck for common cathode)"
            default n
    endif

    if EXAMPLE_DRIVER_74HC595
        config EXAMPLE_595_DATA_PIN
            int "74HC595 DATA (SER) pin"
            default 13
        config EXAMPLE_595_CLK_PIN
            int "74HC595 CLK (SRCLK) pin"
            default 14
        config EXAMPLE_595_LATCH_PIN
            int "74HC595 LATCH (RCLK) pin"
            default 15
        config EXAMPLE_595_COMMON0
            int "Common pin digit 0"
            default 16
        config EXAMPLE_595_COMMON1
            int "Common pin digit 1 (-1 to disable)"
            default -1
        config EXAMPLE_595_COMMON2
            int "Common pin digit 2 (-1 to disable)"
            default -1
        config EXAMPLE_595_COMMON3
            int "Common pin digit 3 (-1 to disable)"
            default -1
        config EXAMPLE_595_DIGIT_COUNT
            int "Number of digits (1-8)"
            default 1
            range 1 8
        config EXAMPLE_595_COMMON_ANODE
            bool "Common anode (uncheck for common cathode)"
            default n
    endif

    if EXAMPLE_DRIVER_MAX7219
        config EXAMPLE_MAX_MOSI_PIN
            int "MAX7219 MOSI pin"
            default 23
        config EXAMPLE_MAX_CLK_PIN
            int "MAX7219 CLK pin"
            default 18
        config EXAMPLE_MAX_CS_PIN
            int "MAX7219 CS pin"
            default 5
        config EXAMPLE_MAX_DIGIT_COUNT
            int "Number of digits (1-8)"
            default 4
            range 1 8
    endif

endmenu
