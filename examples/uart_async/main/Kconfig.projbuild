menu "Blusys UART Async Example"

config BLUSYS_UART_ASYNC_PORT
    int "UART port"
    range 0 1
    default 1
    help
        Select the UART port used for the async loopback example.

config BLUSYS_UART_ASYNC_TX_PIN
    int "UART TX GPIO pin"
    range 0 48
    default 21 if IDF_TARGET_ESP32C3
    default 17 if IDF_TARGET_ESP32S3
    help
        Select a board-safe TX-capable GPIO for this example.

config BLUSYS_UART_ASYNC_RX_PIN
    int "UART RX GPIO pin"
    range 0 48
    default 20 if IDF_TARGET_ESP32C3
    default 18 if IDF_TARGET_ESP32S3
    help
        Select a board-safe RX-capable GPIO for this example.

endmenu
