menu "Blusys I2C Scan Example"

config BLUSYS_I2C_SCAN_PORT
    int "I2C port"
    range 0 1
    default 0
    help
        Select the I2C controller used by this scan example.

config BLUSYS_I2C_SCAN_SDA_PIN
    int "SDA GPIO pin"
    range 0 48
    default 21 if IDF_TARGET_ESP32
    default 8 if IDF_TARGET_ESP32C3
    default 8 if IDF_TARGET_ESP32S3
    help
        Select a board-safe SDA GPIO for this example.

config BLUSYS_I2C_SCAN_SCL_PIN
    int "SCL GPIO pin"
    range 0 48
    default 22 if IDF_TARGET_ESP32
    default 9 if IDF_TARGET_ESP32C3
    default 9 if IDF_TARGET_ESP32S3
    help
        Select a board-safe SCL GPIO for this example.

endmenu
