# ESP32-S3 + SSD1306 128×64 I2C — SDA=GPIO1 / SCL=GPIO2 (see profiles/ssd1306.hpp and dashboard_device_profile).
CONFIG_BLUSYS_DASHBOARD_DISPLAY_PROFILE_SSD1306=y
