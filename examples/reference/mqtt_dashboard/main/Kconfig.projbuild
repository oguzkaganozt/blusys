menu "MQTT Dashboard (display)"

choice BLUSYS_IDASH_DISPLAY_PROFILE
    prompt "Device display profile"
    default BLUSYS_IDASH_DISPLAY_PROFILE_ILI9341
    help
        SPI TFT reference sizes for the dashboard example.

config BLUSYS_IDASH_DISPLAY_PROFILE_ILI9341
    bool "ILI9341 320x240 landscape"

config BLUSYS_IDASH_DISPLAY_PROFILE_ILI9488
    bool "ILI9488 480x320 landscape"

endchoice

endmenu
