# Default interactive_dashboard for ESP32-C3: I2C SSD1306 128×64.
# I2C pins SDA=8 / SCL=9 are applied in integration/app_main.cpp (dashboard_device_profile).
CONFIG_BLUSYS_DASHBOARD_DISPLAY_PROFILE_SSD1306=y
# CONFIG_BLUSYS_DASHBOARD_DISPLAY_PROFILE_ILI9341 is not set
# CONFIG_BLUSYS_DASHBOARD_DISPLAY_PROFILE_ILI9488 is not set
# CONFIG_BLUSYS_DASHBOARD_DISPLAY_PROFILE_ST7735 is not set
# CONFIG_BLUSYS_DASHBOARD_LCD_QEMU_RGB is not set
