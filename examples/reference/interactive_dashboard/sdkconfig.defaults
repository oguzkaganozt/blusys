# LVGL + shell + charts init on the main task exceeds the IDF default on esp32c3 (stack canary).
# 16 KiB: 12 KiB was still marginal for some dashboard init + log paths on RISC-V.
CONFIG_ESP_MAIN_TASK_STACK_SIZE=16384
# First-frame LVGL layout can run long without yielding; default 5s idle-task WDT trips on C3.
CONFIG_ESP_TASK_WDT_TIMEOUT_S=30
CONFIG_LV_FONT_MONTSERRAT_14=y
CONFIG_LV_FONT_MONTSERRAT_20=y
# CONFIG_PARTITION_TABLE_SINGLE_APP is not set
CONFIG_PARTITION_TABLE_CUSTOM=y
CONFIG_PARTITION_TABLE_CUSTOM_FILENAME="partitions.csv"
# CONFIG_ESPTOOLPY_FLASHSIZE_2MB is not set
CONFIG_ESPTOOLPY_FLASHSIZE_4MB=y
