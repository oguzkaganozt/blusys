menu "Blusys Concurrency I2C Test"

config BLUSYS_CONCURRENCY_I2C_PORT
    int "I2C port"
    range 0 1
    default 0
    help
        Select the I2C controller used by this concurrency test.

config BLUSYS_CONCURRENCY_I2C_SDA_PIN
    int "SDA GPIO pin"
    range 0 48
    default 21 if IDF_TARGET_ESP32
    default 8 if IDF_TARGET_ESP32C3
    default 8 if IDF_TARGET_ESP32S3
    help
        Select a board-safe SDA GPIO for this test.

config BLUSYS_CONCURRENCY_I2C_SCL_PIN
    int "SCL GPIO pin"
    range 0 48
    default 22 if IDF_TARGET_ESP32
    default 9 if IDF_TARGET_ESP32C3
    default 9 if IDF_TARGET_ESP32S3
    help
        Select a board-safe SCL GPIO for this test.

endmenu
